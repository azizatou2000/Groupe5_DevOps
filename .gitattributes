# Forcer LF pour tous les fichiers texte
# Sans ça, Windows convertit en CRLF et les scripts shell
# dans les conteneurs Docker refusent de s'exécuter

* text=auto eol=lf

# Fichiers shell et Docker : toujours LF obligatoire
*.sh        text eol=lf
Dockerfile  text eol=lf
Jenkinsfile text eol=lf
*.py        text eol=lf
*.jsx       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
nginx.conf  text eol=lf

# Fichiers binaires : ne pas toucher
*.png  binary
*.jpg  binary
*.ico  binary
*.woff binary
*.woff2 binary
